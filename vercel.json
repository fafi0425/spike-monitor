{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/spike",        "dest": "/server.js" },
    { "src": "/spikes/clear", "dest": "/server.js" },
    { "src": "/spikes",       "dest": "/server.js" },
    { "src": "/(.*)",         "dest": "/server.js" }
  ]
}