{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/spike",        "dest": "/server.js" },
    { "src": "/spikes/clear", "dest": "/server.js" },
    { "src": "/spikes",       "dest": "/server.js" },
    { "src": "/settings",     "dest": "/server.js" },
    { "src": "/(.*)",         "dest": "/server.js" }
  ]
}